# Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Notion Integration token (https://www.notion.so/my-integrations)
NOTION_TOKEN=

# 자동 회의록 DB의 데이터 소스 ID (또는 데이터베이스 ID)
NOTION_DATA_SOURCE_ID=343b23cf-3720-80d2-b027-000be11d1c08
NOTION_DATABASE_ID=343b23cf-3720-805a-885a-ef6795242b77

# 용어집 DB ID (Notion)
NOTION_GLOSSARY_DB_ID=5d02ac8bf3e34a5d9fc0c5ad2eb89583

# 유의어 사전 DB ID (Notion) - 전사 후처리 자동 교정용
NOTION_SYNONYM_DB_ID=6ef2c80e98b74200944255106fb72e0e

# 회의록 작성 가이드 페이지 ID (Notion) - 요약 프롬프트에 규칙 주입
NOTION_GUIDE_PAGE_ID=344b23cf3720813c90bdfdbf36d6da3c

# Vercel Blob (로컬 복구 스크립트 전용)
# Vercel Dashboard → Storage → meeting-audio → .env.local 탭에서 복사
BLOB_READ_WRITE_TOKEN=

# 앱 접근 게이트 (외부 무단 사용 차단용 비밀 토큰).
# 서버가 x-app-token 헤더와 매치 검증, 불일치 시 401. 값이 없으면 게이트 비활성.
# 운영에서는 반드시 Vercel env vars (Production + Preview + Development 모두)에
# 긴 랜덤 문자열 (예: openssl rand -hex 32 결과)을 설정. 로컬에서 `vercel dev` 쓸
# 때만 .env에도 동일 값 필요, 다른 로컬 스크립트(recover/process-locally 등)는
# 서버 경유 안 하므로 불필요.
APP_ACCESS_TOKEN=
